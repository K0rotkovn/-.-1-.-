# Ввод фраз, разделённых символом «;»
phrases = input("Введите фразы, разделённые символом «;»: ").split(";")


# Создание списка lengths с количеством слов в каждой фразе с помощью генератора списка
lengths = [len(phrase.strip().split()) for phrase in phrases]

# Вывод исходного списка и списка lengths
print("Исходный список фраз:", phrases)
print("Список lengths (количество слов в каждой фразе):", lengths)

