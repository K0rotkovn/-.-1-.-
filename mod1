# Ввод чисел через пробел и преобразование в список целых чисел
numbers = list(map(int, input("Введите числа через пробел: ").split()))

# Ввод числа K
K = int(input("Введите число K: "))

# Создание списка чисел, кратных K, с помощью генератора списка
multiples_of_K = [x for x in numbers if x % K == 0]

# Вывод результата
print("Числа, кратные K:", multiples_of_K)

