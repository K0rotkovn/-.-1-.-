# Ввод списка цен через пробел и преобразование в список целых чисел
prices = list(map(int, input("Введите цены на товары через пробел: ").split()))


# Ввод параметров акции: K (каждые K рублей дают скидку) и M (размер скидки в рублях)
K = int(input("Введите число K: "))
M = int(input("Введите число M: "))

# Создание списка discount с ценами после применения скидки с помощью генератора списка
discount = [price - (price // K) * M for price in prices]

# Вывод результатов
print("Цены до скидки:", prices)
print("Цены после скидки:", discount)
