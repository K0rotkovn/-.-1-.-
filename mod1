task 1
# Ввод количества имён
N = int(input("Введите количество имён N: "))

# Создание списка для исходных имён
names = []

# Ввод N имён и добавление их в список
print("Введите имена:")
for _ in range(N):
    name = input()
    names.append(name)

# Создание нового списка для имён разной длины
uni = []
# Множество для хранения уже встреченных длин имён
seen_lengths = set()

# Проход по исходному списку
for name in names:
    length = len(name)
    # Добавляем имя в uni, только если такой длины ещё нет в seen_lengths
    if length not in seen_lengths:
        uni.append(name)
        seen_lengths.add(length)

# Вывод обоих списков
print("\nИсходный список names:", names)
print("Список uni (имена разной длины):", uni)

task 2 
import math

# Ввод числа N
N = int(input("Введите число N: "))

# Создание списка чисел от N до N^2 с помощью range()
numbers = list(range(N, N**2 + 1))  # +1, чтобы включить N^2 в диапазон

# Создание нового списка с квадратными корнями с помощью генератора списка
sqrt_numbers = [math.sqrt(x) for x in numbers]

# Вывод обоих списков
print("Исходный список чисел от N до N^2:", numbers)
print("Список квадратных корней:", sqrt_numbers)

