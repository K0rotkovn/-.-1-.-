import re

def extract_emails(text):
    """
    Извлекает email‑адреса из текста согласно заданным правилам.

    Email может содержать:
    * буквы латинского алфавита (A–Z, a–z);
    * цифры (0–9);
    * спецсимволы: +, _, -, #.

    Args:
        text (str): Текст для поиска email‑адресов.

    Returns:
        list: Список найденных email‑адресов.
    """
    # Регулярное выражение для поиска email
    # Локальная часть: буквы, цифры и разрешённые спецсимволы (+_ - #)
    # Символ @
    # Доменная часть: буквы, цифры, дефисы, точки; минимум одна точка перед доменом верхнего уровня
    pattern = r'[a-zA-Z0-9+_#-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*\.[a-zA-Z]{2,}'
    
    emails = re.findall(pattern, text)
    return emails

# Пример использования
if __name__ == '__main__':
    # Тестовый текст с разными email‑адресами
    test_text = """
    Свяжитесь с нами:
    user@example.com
    test.email+tag@domain.co.uk
    another_user123@sub.domain.org
    special#char@site.net
    invalid-email@
    @missinglocalpart.com
    localpart@.missingdomain
    valid.email@domain.info
    user+label@company.io
    simple@site.com
    """

    found_emails = extract_emails(test_text)

    print("Найденные email‑адреса:")
    for email in found_emails:
        print(email)
